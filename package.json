{
  "name": "rakit-cli",
  "version": "0.1.1",
  "description": "Rakit adalah CLI coding assistant sederhana berbasis OpenRouter, OpenAI Codex, Anthropic, Gemini, Groq, dan Ollama.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "rakit": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "version:check": "node scripts/version-check.mjs",
    "test": "npm run build && node --test tests/*.test.mjs",
    "validate": "npm run version:check && npm run check && npm run test && npm audit --audit-level=moderate",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "ai",
    "coding-agent",
    "openrouter",
    "openai-codex",
    "anthropic",
    "gemini",
    "groq",
    "ollama",
    "terminal"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@clack/prompts": "^1.3.0",
    "cli-highlight": "^2.1.11",
    "commander": "^12.1.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "picocolors": "^1.1.1",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
